<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="OpacMauiApp.Pages.DigitalContSearchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Digital Content Search"
    BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto,*">

        <!-- Search Area -->

        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="15">

                <Frame
                    BackgroundColor="White"
                    CornerRadius="15"
                    Padding="15"
                    BorderColor="#E5E7EB">

                    <VerticalStackLayout Spacing="8">

                        <Label
                            Text="Digital Content Search"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#111827"/>

                        <Entry
                            HeightRequest="42"
                            Placeholder="Title"
                            Text="{Binding Title}" />

                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="10">

                            <Button
                                Text="Search"
                                Command="{Binding SearchCommand}"
                                BackgroundColor="#16A34A"
                                TextColor="White"/>

                            <Button
                                Grid.Column="1"
                                Text="Reset"
                                Command="{Binding ResetCommand}"
                                BackgroundColor="#DC2626"
                                TextColor="White"/>

                        </Grid>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

        <!-- Data -->

        <Grid Grid.Row="1">

            <ActivityIndicator
                IsVisible="{Binding IsBusy}"
                IsRunning="{Binding IsBusy}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Color="Green"/>

            <CollectionView
                Margin="15,5"
                ItemsSource="{Binding Contents}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                            Margin="0,0,0,12"
                            Padding="15"
                            CornerRadius="12"
                            BorderColor="#E5E7EB"
                            BackgroundColor="White">

                            <VerticalStackLayout Spacing="8">

                                <Label
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    Text="{Binding Title}"
                                    TextColor="#1F2937"/>

                                <BoxView
                                    HeightRequest="1"
                                    BackgroundColor="#E5E7EB"/>

                                <Grid
ColumnDefinitions="150,*"
RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
RowSpacing="8">

                                    <Label
                                        Text="Description :"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Descr}"/>

                                    <Label
                                        Grid.Row="1"
                                        Text="Date Saved :"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding DateSaved,StringFormat='{0:dd-MMM-yyyy}'}"/>

                                    <Label
                                        Grid.Row="2"
                                        Text="Content Type :"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Text="{Binding ContentType}"/>

                                    <Label
                                        Grid.Row="3"
                                        Text="Audience :"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Text="{Binding Audience}"/>

                                    <Label
                                        Grid.Row="4"
                                        Text="Files :"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Text="{Binding NoOfFiles}"/>

                                </Grid>

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>